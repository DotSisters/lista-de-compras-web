@{
  Layout = "_Layout";
  ViewBag.Titulo = "Listas de Compras";
  ViewBag.Info = "Gerencie suas listas de compras com facilidade, mantendo tudo organizado e pronto para suas próximas compras.";
}

@model List<ListarListasDeComprasViewModel>;

<a class="btn btn-primary rounded-pill px-4 mb-4" asp-action="Cadastrar">Cadastrar Lista</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
    Nenhuma lista cadastrada.
  </div>
}
else
{
  <div class="table-responsive">
    <table class="table table-hover table-bordered align-middle bg-white">
      <thead class="table-primary">
        <tr>
          <th>Nome</th>
          <th>ID</th>
          <th>Status</th>
          <th>Data de Criação</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        @foreach (ListarListasDeComprasViewModel l in Model)
        {
          <tr>
            <td class="fw-semibold">@l.Nome</td>
            <td>@l.Id</td>
            <td>
              <span
              class="badge rounded-pill @(
              l.Status == "Aberta" ? "bg-success" :
              l.Status == "Concluída" ? "bg-dark text-white" :
              "bg-secondary text-white"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        )">@l.Status</span>
            </td>
            <td>@l.DataCriacao.ToString("dd/MM/yyyy")</td>
            <td>
              <div class="d-flex flex-sm-row flex-column gap-2">
                <a class="btn btn-primary btn-sm rounded-pill px-3" asp-controller="ItemLista" asp-action="Listar"
                   asp-route-listaId="@l.Id">Itens</a>
                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                   asp-route-id="@l.Id">Editar</a>
                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                   asp-route-id="@l.Id">Excluir</a>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
