@using ListaDeComprasWeb.WebApp.ModuloListaCompras.Dominio

@{
  Layout = "_Layout";
  ViewBag.Titulo = "Editar Lista de Compras";
  ViewBag.Info = "Registre um novo nome e/ou altere o status desta lista de compras.";

}

@model EditarListaDeComprasViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Editar"
      asp-route-id="@Model.Id" method="post">

  <input type="hidden" asp-for="Id" />

  <div class="mb-4">
    <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
    <input asp-for="Nome" type="text" class="form-control">
    <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
  </div>

  <div class="mb-4">
    <label asp-for="Status" class="form-label fw-semibold text-primary text-uppercase small">Status</label>
    <select asp-for="Status" asp-items="Html.GetEnumSelectList<StatusListaCompras>()" class="form-select"></select>
    <span asp-validation-for="Status" class="text-danger small"></span>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
    <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
  </div>
</form>
