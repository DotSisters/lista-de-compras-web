@{
  Layout = "_Layout";
  ViewBag.Titulo = "Excluir Categoria";
  ViewBag.Info = "Confirme a exclusão desta categoria de produto.";
}

@model ExcluirCategoriaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
      asp-action="Excluir" asp-route-id="@Model.Id" method="post">

  <input type="hidden" asp-for="Id" />

  <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
    Tem certeza que deseja excluir esta categoria?
  </div>

  <div class="mb-4">
    <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
    <input asp-for="Nome" type="text" class="form-control border-primary-subtle shadow-sm bg-transparent" disabled>
  </div>

  <div class="mb-4">
    <label asp-for="Cor" class="form-label fw-semibold text-primary text-uppercase small">Cor</label>
    <input asp-for="Cor" type="text" class="form-control border-primary-subtle shadow-sm bg-transparent" disabled>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
    <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
  </div>
</form>
