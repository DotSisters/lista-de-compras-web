@using ListaDeComprasWeb.WebApp.ModuloCategoria.Dominio
@{
  Layout = "_Layout";
  ViewBag.Titulo = "Categorias";
  ViewBag.Info = "Cadastre, visualize e gerencie categorias de produtos.";
}

@model List<ListarCategoriasViewModel>;

@functions {
  private string ObterClasseBadge(CorCategoria cor) => cor switch
  {
    CorCategoria.Branca => "badge bg-light text-dark border border-secondary",
    CorCategoria.Vermelha => "badge bg-danger",
    CorCategoria.Verde => "badge bg-success",
    CorCategoria.Azul => "badge bg-primary",
    _ => "badge bg-secondary"
  };
}

<a class="btn btn-primary rounded-pill px-4 mb-4" asp-action="Cadastrar">Cadastrar Categoria</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
    Nenhuma categoria cadastrada.
  </div>
}
else
{
  <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
    @foreach (ListarCategoriasViewModel c in Model)
    {
      <div class="col">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between mb-3">
              <h5 class="card-title mb-0">@c.Nome</h5>
              <span class="badge text-bg-warning rounded-pill">#@c.Id</span>
            </div>

            <dl class="row align-items-center g-2 mb-4">
              <dt class="col-auto text-secondary fw-semibold">Cor</dt>
              <dd class="col-auto mb-0">
                <span class="@ObterClasseBadge(c.Cor)">@c.Cor</span>
              </dd>
            </dl>

            <div class="d-flex flex-wrap gap-2 mt-auto justify-content-start">
              <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                 asp-route-id="@c.Id">Editar</a>
              <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                 asp-route-id="@c.Id">Excluir</a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
}
