@{
  Layout = "_Layout";
  ViewBag.Titulo = "Produtos";
  ViewBag.Info = "Cadastre, visualize e gerencie produtos para adicioná-los nas suas listas de compras.";
}

@model List<ListarProdutosViewModel>;

@* <style>
  .table-transparent,
  .table-transparent tbody tr,
  .table-transparent tbody tr td,
  .table-transparent thead th {
    background-color: transparent !important;
  }

  .table-thicker-borders,
  .table-thicker-borders th,
  .table-thicker-borders td {
    border-width: 2px !important;
    border-color: #B9D3EE !important;
  }
</style> *@

<a class="btn btn-primary rounded-pill px-4 mb-4" asp-action="Cadastrar">Cadastrar Produto</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
  <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
    @mensagemErro
  </div>
}

@if (Model.Count == 0)
{
  <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
    Nenhum produto cadastrado.
  </div>
}
else
{
  <div class="table-responsive">
    <table class="table table-hover table-bordered align-middle bg-white">
      <thead class=" table-primary">
        <tr>
          <th>ID</th>
          <th>Nome</th>
          <th>Unidade de Medida</th>
          <th>Preço Aproximado</th>
          <th>Categoria</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        @foreach (ListarProdutosViewModel p in Model)
        {
          <tr class="bg-transparent">
            <td>@p.Id</td>
            <td>@p.Nome</td>
            <td>@p.UnidadeMedida</td>
            <td>@p.PrecoAproximado</td>
            <td>@p.CategoriaNome</td>
            <td>
              <div class="d-flex flex-sm-row flex-column gap-2">
                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                   asp-route-id="@p.Id">Editar</a>
                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                   asp-route-id="@p.Id">Excluir</a>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
