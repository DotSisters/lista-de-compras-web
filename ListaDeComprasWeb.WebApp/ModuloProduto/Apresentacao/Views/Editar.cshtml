@{
Layout = "_Layout";
ViewBag.Titulo = "Edição de Produto";
}

@model EditarProdutoViewModel;

@if (Model.Categorias.Count == 0)
{
<div class="alert alert-primary border-start border-primary border-4 rounded-3 mx-auto" style="max-width: 620px;"
    role="alert">
    Cadastre uma categoria antes de cadastrar/editar produtos.
</div>
}

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Editar"
    asp-route-id="@Model.Id" method="post">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control">
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UnidadeMedida" class="form-label fw-semibold text-primary text-uppercase small">Unidade de
            Medida</label>
        <input asp-for="UnidadeMedida" type="text" class="form-control">
        <span asp-validation-for="UnidadeMedida" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PrecoAproximado" class="form-label fw-semibold text-primary text-uppercase small">Preço
            Aproximado</label>
        <input asp-for="PrecoAproximado" type="number" min="1" class="form-control">
        <span asp-validation-for="PrecoAproximado" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoriaNome"
            class="form-label fw-semibold text-primary text-uppercase small">Categoria</label>
        <select asp-for="CategoriaNome" class="form-select">
            <option value="">Selecione uma categoria</option>
            @foreach (OpcaoCategoriaViewModel categoria in Model.Categorias)
            {
            <option value="@categoria.Id">@categoria.Nome</option>
            }
        </select>
        <span asp-validation-for="CategoriaNome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        @if (Model.Categorias.Count == 0)
        {
        <button class="btn btn-primary rounded-pill px-4" type="submit" disabled>Confirmar</button>
        }
        else
        {
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
        }
    </div>
</form>