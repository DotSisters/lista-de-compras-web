@{
  Layout = "_Layout";
  DadosCadastroItemListaViewModel dados = ViewBag.DadosCadastro;
  ViewBag.Titulo = "Cadastrar Item";
  ViewBag.Info = "Selecione um produto e defina a quantidade.";
}

@model CadastrarItemDaListaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar"
      method="post">

  <input asp-for="ListaId" type="hidden" />

  <div class="mb-3">
    <label asp-for="ProdutoId" class="form-label">Produto</label>
    <select asp-for="ProdutoId" class="form-select">
      <option value="">Selecione um produto</option>

      @foreach (DadosProdutoViewModel produto in dados.Produtos)
      {
        <option value="@produto.Id">
          @produto.Nome - @produto.NomeCategoria - @produto.PrecoAproximado.ToString("C")
        </option>
      }
    </select>
    <span asp-validation-for="ProdutoId" class="text-danger small"></span>
  </div>

  <div class="mb-4">
    <label asp-for="Quantidade" class="form-label">Quantidade</label>
    <input asp-for="Quantidade" class="form-control" type="number" min="0.01" step="0.01" />
    <span asp-validation-for="Quantidade" class="text-danger small"></span>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="ItemLista" asp-action="Listar"
       asp-route-listaId="@Model.ListaId">Voltar</a>
    <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
  </div>
</form>
