@{
  Layout = "_Layout";
  ViewBag.Titulo = "Exclusão de Item da Lista";
}

@model ExcluirItemDaListaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Excluir"
      asp-route-id="@Model.Id" method="post">

  <input type="hidden" asp-for="Id" />
  <input type="hidden" asp-for="IdLista" />

  <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
    Tem certeza que deseja remover este item da lista?
  </div>

  <dl class="row mb-0">
    <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Lista</dt>
    <dd class="col-sm-8">@Model.NomeLista</dd>

    <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Produto</dt>
    <dd class="col-sm-8">@Model.NomeProduto</dd>

    <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Categoria</dt>
    <dd class="col-sm-8">@Model.NomeCategoria</dd>

    <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Quantidade</dt>
    <dd class="col-sm-8">@Model.Quantidade</dd>

    <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Preço aproximado</dt>
    <dd class="col-sm-8">@Model.PrecoAproximado.ToString("C")</dd>

    <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Valor total</dt>
    <dd class="col-sm-8">@Model.ValorTotal.ToString("C")</dd>
  </dl>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-primary rounded-pill px-4 mt-2" asp-controller="ListaCompras"
       asp-action="Listar">Voltar</a>

    <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
  </div>
</form>
