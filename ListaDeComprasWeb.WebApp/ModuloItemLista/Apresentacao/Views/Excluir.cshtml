@{
  Layout = "_Layout";
  ViewBag.Titulo = "Excluir Item";
  ViewBag.Info = "Confirme a exclusão deste item da lista.";
}

@model ExcluirItemDaListaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4 bg-transparent" style="max-width: 620px;"
      asp-action="Excluir" asp-route-id="@Model.Id" method="post">

  <input type="hidden" asp-for="Id" />
  <input type="hidden" asp-for="IdLista" />

  <div class="alert alert-warning border-start border-primary border-1 rounded-3" role="alert">
    Tem certeza que deseja remover este item da lista?
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <label class="form-label fw-semibold text-primary text-uppercase small">Lista</label>
      <input type="text" class="form-control" value="@Model.NomeLista" disabled>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold text-primary text-uppercase small">Produto</label>
      <input type="text" class="form-control" value="@Model.NomeProduto" disabled>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <label class="form-label fw-semibold text-primary text-uppercase small">Categoria</label>
      <input type="text" class="form-control" value="@Model.NomeCategoria" disabled>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold text-primary text-uppercase small">Quantidade</label>
      <input type="text" class="form-control" value="@Model.Quantidade" disabled>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <label class="form-label fw-semibold text-primary text-uppercase small">Preço Aproximado</label>
      <input type="text" class="form-control" value="@Model.PrecoAproximado.ToString("C")" disabled>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold text-primary text-uppercase small">Valor Total</label>
      <input type="text" class="form-control" value="@Model.ValorTotal.ToString("C")" disabled>
    </div>
  </div>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar"
       asp-route-listaId="@Model.IdLista">Voltar</a>
    <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
  </div>
</form>

