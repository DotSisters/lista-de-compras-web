@{
  Layout = "_Layout";
  ViewBag.Titulo = "Itens da Lista";
  ViewBag.Info = "Cadastre, visualize e exclua itens desta lista de compras.";

  string listaId = Model.Count > 0
       ? Model.First().IdLista
       : Context.Request.Query["listaId"].ToString();

  string nomeLista = Model.Count > 0
      ? Model.First().NomeLista
      : "Lista de Compras";

  decimal valorTotal = Model.Sum(i => i.ValorTotal);
}

@model List<ListarItensDaListaViewModel>

<a class="btn btn-primary rounded-pill px-4 mb-4" asp-action="Cadastrar" asp-route-listaId="@listaId"> Cadastrar
  Item</a>

  @if (Model.Count == 0)
  {
    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
      Nenhum item adicionado nesta lista.
    </div>
  }
  else
  {
    <div class="table-responsive">
      <table class="table table-hover table-bordered align-middle bg-white">
        <thead class="table-primary">
          <tr>
            <th>Produto</th>
            <th>Categoria</th>
            <th>Quantidade</th>
            <th>Preço aproximado</th>
            <th>Valor total</th>
            <th>Ações</th>
          </tr>
        </thead>

        <tbody>
          @foreach (ListarItensDaListaViewModel i in Model)
          {
            <tr>
              <td class="fw-semibold">@i.NomeProduto</td>
              <td>
                <span class="fw-regular">@i.NomeCategoria</span>
              </td>
              <td>@i.Quantidade</td>
              <td>@i.PrecoAproximado.ToString("C")</td>
              <td>@i.ValorTotal.ToString("C")</td>
              <td>
                <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir" asp-route-id="@i.Id">
                  Excluir
                </a>
              </td>
            </tr>
          }
        </tbody>

        <tfoot>
          <tr>
            <th colspan="4" class="text-end">Total estimado</th>
            <th>@valorTotal.ToString("C")</th>
            <th></th>
          </tr>
        </tfoot>
      </table>
    </div>

  }

  <a class="btn btn-outline-primary rounded-pill px-4 mt-2" asp-controller="ListaCompras" asp-action="Listar">Voltar</a>
