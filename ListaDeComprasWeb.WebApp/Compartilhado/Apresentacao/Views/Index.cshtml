@{
  Layout = "_Layout";
  ViewBag.Titulo = "Página Inicial";
}

<div class="row">
  <div class="col-lg-7">
    <h1 class="display-5 fw-semibold mb-3">Lista de Compras</h1>
    <p class="lead text-secondary mb-4">
      Organize a rotina de compras da família cadastrando produtos, criando listas e registrando as compras
      realizadas.
    </p>

    <a class="btn btn-primary rounded-pill px-4 mb-3" asp-controller="Categoria" asp-action="Listar">
      Categorias</a>
      <a class="btn btn-primary rounded-pill px-4 mb-3" asp-controller="Produto" asp-action="Listar">
        Produtos</a>
        <a class="btn btn-primary rounded-pill px-4 mb-3" asp-controller="ListaCompras" asp-action="Listar">
          Listas de Compras</a>
        </div>

        <div class="col-lg-5">
          <div class="card border-primary-subtle shadow-sm bg-transparent">
            <div class="card-body p-4 bg-transparent">
              <h3 class="h5 text-primary mb-3">Módulos disponíveis</h3>

              <div class="list-group">
                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-transparent fw-semibold"
                   asp-controller="Categoria" asp-action="Listar">
                  Controle de Categorias
                  <span class="badge text-bg-success rounded-pill">Abrir</span>
                </a>

                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-transparent fw-semibold"
                   asp-controller="Produto" asp-action="Listar">
                  Controle de Produtos
                  <span class="badge text-bg-success rounded-pill">Abrir</span>
                </a>

                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center bg-transparent fw-semibold"
                   asp-controller="ListaCompras" asp-action="Listar">
                  Controle de Listas de Compras
                  <span class="badge text-bg-success rounded-pill">Abrir</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
